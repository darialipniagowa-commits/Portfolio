@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components.Routing

@inject IStringLocalizer<NavMenu> L
@inject NavigationManager Navigation

<header class="top-bar">
    <a href="/" class="site-seal-link" aria-label="Home">
        <img src="/about/logonav.png" alt="" class="site-seal-img" />
    </a>

    <nav class="site-nav" aria-label="Main navigation">
        <NavLink href="/about" Match="NavLinkMatch.All">@L["About"]</NavLink>
        <NavLink href="/gallery">@L["Art Gallery"]</NavLink>
        <NavLink href="/projects">@L["Projects"]</NavLink>
        <NavLink href="/exhibitions">@L["Exhibitions"]</NavLink>
        <NavLink href="/offers">@L["Offers & Contacts"]</NavLink>
    
    </nav>

    <div class="lang-switch">
        <a href="@CultureUrl("lv")">LV</a>
        <span>|</span>
        <a href="@CultureUrl("en")">EN</a>
    </div>
</header>

@code {
    private string CultureUrl(string culture)
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);

        if (string.IsNullOrWhiteSpace(path))
        {
            path = "about";
        }

        return $"/set-culture/{culture}?returnUrl=/{path}";
    }
}