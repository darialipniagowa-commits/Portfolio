@page "/"
@page "/about"
@rendermode InteractiveServer
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components.Authorization
@inject IStringLocalizer<About> L
@inject NavigationManager Navigation

<PageTitle>@L["Title"]</PageTitle>

<section class="about-section">
    <div class="about-container">
        <div class="about-image">
            <div>
                <div class="about-image-frame">
                    <img src="/images/profile.jpg" alt="Darja Lipņagova" />
                </div>

                <div class="about-decor-panel">
                    <p class="about-decor-text">Calligraphy · Xieyi · Chinoiserie</p>
                </div>
            </div>
        </div>

        <div class="about-text">
            <div class="about-heading">
                <h1 class="about-title">@L["Title"]</h1>
            </div>

            <p>@L["Paragraph1"]</p>
            <p>@L["Paragraph2"]</p>
            <p>@L["Paragraph3"]</p>
            <p>@L["Paragraph4"]</p>
            <p>@L["Paragraph5"]</p>
            <p>@L["Paragraph6"]</p>

            <div class="about-footer">
                <div class="about-links">
                    <a class="social-icon"
                           href="https://www.instagram.com/dariustilius/"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="Instagram">
                        <i class="fa-brands fa-instagram"></i>
                    </a>

                    <a class="social-icon"
                           href="https://github.com/darialipniagowa"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="GitHub">
                        <i class="fa-brands fa-github"></i>
                    </a>

                    <a class="social-icon"
                           href="https://www.linkedin.com/in/daria-lipniagowa-4616a8122/"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="LinkedIn">
                        <i class="fa-brands fa-linkedin-in"></i>
                    </a>
                </div>

                <div class="about-admin-tools">
                    <AuthorizeView>
                        <Authorized>
                            <button type="button" class="admin-icon-btn" @onclick="GoToAdmin" title="Admin" aria-label="Admin">
                                🔓
                            </button>

                            <button type="button" class="admin-icon-btn" @onclick="Logout" title="Logout" aria-label="Logout">
                                🚪
                            </button>
                        </Authorized>

                        <NotAuthorized>
                            <button type="button" class="admin-icon-btn" @onclick="GoToLogin" title="Login" aria-label="Login">
                                🔒
                            </button>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private void GoToLogin()
    {
        Navigation.NavigateTo("/account/login", forceLoad: true);
    }

    private void GoToAdmin()
    {
        Navigation.NavigateTo("/admin", forceLoad: true);
    }

    private void Logout()
    {
        Navigation.NavigateTo("/account/logout", forceLoad: true);
    }
}