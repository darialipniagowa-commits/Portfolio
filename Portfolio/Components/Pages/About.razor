@page "/"
@page "/about"
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<About> L

<PageTitle>@L["Title"]</PageTitle>

<section class="about-section">
    <div class="about-container">
        <div class="about-image">
            <img src="/images/profilepic.jpg" alt="Darja Lipņagova" />
        </div>

        <div class="about-text">
            <h1>@L["Title"]</h1>

            <p>@L["Paragraph1"]</p>
            <p>@L["Paragraph2"]</p>
            <p>@L["Paragraph3"]</p>
            <p>@L["Paragraph4"]</p>
            <p>@L["Paragraph5"]</p>
            <p>@L["Paragraph6"]</p>

            <div class="about-links">
                <a href="https://instagram.com" target="_blank" aria-label="Instagram" class="social-icon">
                    <!-- Instagram SVG -->
                    <svg viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.5" />
                        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" />
                        <circle cx="17" cy="7" r="1" fill="currentColor" />
                    </svg>
                </a>

                <a href="https://github.com" target="_blank" aria-label="GitHub" class="social-icon">
                    <!-- GitHub SVG -->
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 .5C5.65.5.75 5.4.75 11.75c0 5.08 3.29 9.39 7.86 10.92.57.1.78-.25.78-.56v-2.1c-3.2.7-3.88-1.54-3.88-1.54-.53-1.35-1.3-1.71-1.3-1.71-1.07-.73.08-.72.08-.72 1.18.08 1.8 1.22 1.8 1.22 1.05 1.8 2.75 1.28 3.42.98.1-.77.41-1.28.75-1.57-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.3 1.2-3.11-.12-.3-.52-1.5.11-3.13 0 0 .97-.31 3.18 1.19a11 11 0 0 1 5.8 0c2.21-1.5 3.18-1.19 3.18-1.19.63 1.63.23 2.83.11 3.13.75.81 1.2 1.85 1.2 3.11 0 4.43-2.7 5.4-5.27 5.68.42.36.8 1.08.8 2.18v3.23c0 .31.21.67.79.56a11.26 11.26 0 0 0 7.85-10.92C23.25 5.4 18.35.5 12 .5z" />
                    </svg>
                </a>

                <a href="https://linkedin.com" target="_blank" aria-label="LinkedIn" class="social-icon">
                    <!-- LinkedIn SVG -->
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.5 8h4v14h-4V8zm7.5 0h3.83v1.92h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V22h-4v-6.97c0-1.66-.03-3.8-2.32-3.8-2.32 0-2.68 1.81-2.68 3.68V22h-4V8z" />
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>