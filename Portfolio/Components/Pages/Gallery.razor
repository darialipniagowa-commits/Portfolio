@page "/gallery"
@rendermode InteractiveServer

@using Portfolio.Models
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components.Forms
@inject IStringLocalizer<Gallery> L
@inject Portfolio.Services.AdminState AdminState
@inject Portfolio.Services.ArtworkService ArtworkService
@inject Portfolio.Services.PurchaseRequestService PurchaseRequestService

<PageTitle>@L["Title"]</PageTitle>

<section class="gallery-section">
    <div class="gallery-container">
        <div class="gallery-content">

            <div class="gallery-heading">
                <img class="gallery-header-image"
                     src="@HeaderImage"
                     alt="@L["Title"]" />
            </div>

            @if (AdminState.IsAdmin)
            {
                <div class="gallery-admin-actions">
                    <button class="add-btn" type="button" @onclick="ToggleForm">
                        @(showForm ? "Close" : "+ Add Artwork")
                    </button>
                </div>
            }

            @if (AdminState.IsAdmin && showForm)
            {
                <AdminArtworks FormModel="formModel"
                               UploadedFileChanged="OnUploadedFileChanged"
                               OnSubmit="AddArtwork" />
            }

            @if (AdminState.IsAdmin)
            {
                @if (artworks.Any())
                {
                    <div class="gallery-grid">
                        @foreach (var artwork in artworks)
                        {
                            <GalleryCard Artwork="artwork"
                                         IsAdmin="true"
                                         OnDelete="DeleteArtwork"
                                         OnBuy="OpenPurchaseForm" />
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state">@L["EmptyCategory"]</p>
                }
            }
            else
            {
                @if (string.IsNullOrWhiteSpace(selectedFlow))
                {
                    <div class="public-category-grid">
                        <button type="button"
                                class="public-category-card"
                                @onclick='() => OpenCategory("Calligraphy")'>
                            <img class="category-switch-image"
                                 src="@CalligraphyCategoryImage"
                                 alt="@L["Calligraphy"]" />
                        </button>

                        <button type="button"
                                class="public-category-card"
                                @onclick='() => OpenCategory("Xieyi")'>
                            <img class="category-switch-image"
                                 src="@XieyiCategoryImage"
                                 alt="@L["Xieyi"]" />
                        </button>

                        <button type="button"
                                class="public-category-card"
                                @onclick='() => OpenCategory("Chinoiserie")'>
                            <img class="category-switch-image"
                                 src="@ChinoiserieCategoryImage"
                                 alt="@L["Chinoiserie"]" />
                        </button>
                    </div>
                }
                else
                {
                    var categoryArtworks = artworks
                        .Where(a => a.Flow == selectedFlow)
                        .ToList();

                    <div class="public-gallery-view">
                        <div class="public-gallery-header">
                            <button type="button"
                                    class="back-btn"
                                    @onclick="BackToCategories">
                                ← Back
                            </button>

                            <h2 class="gallery-group-title">@GetCategoryTitle(selectedFlow)</h2>
                        </div>

                        @if (categoryArtworks.Any())
                        {
                            <div class="gallery-grid">
                                @foreach (var artwork in categoryArtworks)
                                {
                                    <GalleryCard Artwork="artwork"
                                                 IsAdmin="false"
                                                 OnDelete="DeleteArtwork"
                                                 OnBuy="OpenPurchaseForm" />
                                }
                            </div>
                        }
                        else
                        {
                            <p class="empty-state">@L["EmptyCategory"]</p>
                        }
                    </div>
                }
            }

        </div>
    </div>

    @if (showPurchaseForm && selectedArtwork is not null)
    {
        <div class="purchase-modal">
            <div class="purchase-card">

                <button type="button"
                        class="purchase-close"
                        @onclick="ClosePurchaseForm">
                    ×
                </button>

                <h2>Purchase request</h2>

                <p class="purchase-artwork-name">@selectedArtwork.Title</p>
                <p class="purchase-artwork-price">@selectedArtwork.Price €</p>

                <p class="purchase-note">
                    Shipping is calculated separately after request confirmation.
                    Payment can be arranged by Revolut or bank transfer.
                </p>

                <EditForm Model="purchaseRequest" OnSubmit="SubmitPurchaseRequest">
                    <div class="purchase-form-grid">
                        <InputText class="form-input" placeholder="Your name" @bind-Value="purchaseRequest.BuyerName" />
                        <InputText class="form-input" placeholder="Email" @bind-Value="purchaseRequest.Email" />

                        <InputText class="form-input" placeholder="Phone optional" @bind-Value="purchaseRequest.Phone" />
                        <InputText class="form-input" placeholder="Country" @bind-Value="purchaseRequest.Country" />

                        <InputText class="form-input" placeholder="City" @bind-Value="purchaseRequest.City" />
                        <InputText class="form-input" placeholder="Postal code" @bind-Value="purchaseRequest.PostalCode" />

                        <InputText class="form-input full-width" placeholder="Full address" @bind-Value="purchaseRequest.Address" />

                        <InputSelect class="form-input full-width" @bind-Value="purchaseRequest.DeliveryPreference">
                            <option value="Courier">Courier</option>
                            <option value="Parcel locker">Parcel locker</option>
                            <option value="Pickup in Riga">Pickup in Riga</option>
                        </InputSelect>

                        <InputTextArea class="form-input full-width" placeholder="Message" @bind-Value="purchaseRequest.Message" />
                    </div>

                    <button type="submit" class="save-btn">
                        Send request
                    </button>
                </EditForm>

                @if (purchaseSent)
                {
                    <p class="purchase-success">
                        Thank you. Your request was sent.
                    </p>
                }

            </div>
        </div>
    }
</section>

@code {
    private string? selectedFlow;
    private bool showForm;
    private IBrowserFile? uploadedFile;

    private List<ArtworkItem> artworks = new();

    private ArtworkItem? selectedArtwork;
    private bool showPurchaseForm;
    private bool purchaseSent;

    private PurchaseRequest purchaseRequest = new();

    private ArtworkFormModel formModel = new()
    {
        Flow = "Calligraphy"
    };

    private bool IsLv =>
        System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "lv";

    private string HeaderImage =>
        IsLv ? "/gallery/name2.png" : "/gallery/finseng.png";

    private string CalligraphyCategoryImage =>
        IsLv ? "/gallery/lv1.png" : "/gallery/eng1.png";

    private string XieyiCategoryImage =>
        IsLv ? "/gallery/lv2.png" : "/gallery/eng2.png";

    private string ChinoiserieCategoryImage =>
        IsLv ? "/gallery/lv3.png" : "/gallery/eng3.png";

    protected override async Task OnInitializedAsync()
    {
        artworks = await ArtworkService.GetArtworksAsync();
    }

    private void ToggleForm()
    {
        showForm = !showForm;
    }

    private void OpenCategory(string flow)
    {
        selectedFlow = flow;
    }

    private void BackToCategories()
    {
        selectedFlow = null;
    }

    private string GetCategoryTitle(string flow) => flow switch
    {
        "Calligraphy" => L["Calligraphy"],
        "Xieyi" => L["Xieyi"],
        "Chinoiserie" => L["Chinoiserie"],
        _ => flow
    };

    private void OnUploadedFileChanged(IBrowserFile? file)
    {
        uploadedFile = file;
    }

    private async Task AddArtwork()
    {
        var imageUrl = "/images/placeholder.jpg";

        if (uploadedFile is not null)
        {
            imageUrl = await ArtworkService.SaveImageAsync(uploadedFile);
        }

        var artwork = new ArtworkItem
        {
            Id = Guid.NewGuid(),
            Title = formModel.Title,
            Size = formModel.Size,
            Material = formModel.Material,
            Year = formModel.Year,
            Description = formModel.Description,
            Flow = formModel.Flow,
            Price = formModel.Price,
            ImageUrl = imageUrl
        };

        await ArtworkService.AddArtworkAsync(artwork);

        artworks = await ArtworkService.GetArtworksAsync();

        formModel = new ArtworkFormModel
        {
            Flow = "Calligraphy"
        };

        uploadedFile = null;
        showForm = false;
    }

    private void OpenPurchaseForm(ArtworkItem artwork)
    {
        selectedArtwork = artwork;
        purchaseSent = false;

        purchaseRequest = new PurchaseRequest
        {
            ArtworkId = artwork.Id,
            ArtworkTitle = artwork.Title,
            ArtworkPrice = artwork.Price ?? 0,
            DeliveryPreference = "Courier"
        };

        showPurchaseForm = true;
    }

    private void ClosePurchaseForm()
    {
        showPurchaseForm = false;
        selectedArtwork = null;
        purchaseSent = false;
    }
    private async Task SubmitPurchaseRequest()
    {
        if (selectedArtwork is null)
            return;

        purchaseRequest.ArtworkId = selectedArtwork.Id;
        purchaseRequest.ArtworkTitle = selectedArtwork.Title;
        purchaseRequest.ArtworkPrice = selectedArtwork.Price ?? 0;

        await PurchaseRequestService.AddRequestAsync(purchaseRequest);

        purchaseSent = true;
    }

    private async Task DeleteArtwork(Guid id)
    {
        await ArtworkService.DeleteArtworkAsync(id);

        artworks = await ArtworkService.GetArtworksAsync();
    }
}