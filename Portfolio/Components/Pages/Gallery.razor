@page "/gallery"
@rendermode InteractiveServer

@using Portfolio.Models
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Gallery> L
@inject Portfolio.Services.AdminState AdminState

<PageTitle>@L["Title"]</PageTitle>

<section class="gallery-section">
    <div class="gallery-container">
        <div class="gallery-content">

            <div class="gallery-heading">
                <h1 class="gallery-title">@L["Title"]</h1>

                @if (AdminState.IsAdmin)
                {
                    <button class="add-btn" type="button" @onclick="ToggleForm">
                        @(showForm ? "Close" : "+ Add Artwork")
                    </button>
                }
            </div>

            @if (AdminState.IsAdmin && showForm)
            {
                <AdminArtworks FormModel="formModel"
                               UploadedFileChanged="OnUploadedFileChanged"
                               OnSubmit="AddArtwork" />
            }

            @if (AdminState.IsAdmin)
            {
                @if (artworks.Any())
                {
                    <div class="gallery-grid">
                        @foreach (var artwork in artworks)
                        {
                            <div class="gallery-card">
                                <div class="gallery-card-frame">
                                    <button type="button"
                                            class="delete-icon"
                                            @onclick="() => DeleteArtwork(artwork.Id)">
                                        ×
                                    </button>

                                    <div class="gallery-image-wrap">
                                        <img class="gallery-image" src="@artwork.ImageUrl" alt="@artwork.Title" />
                                    </div>

                                    <div class="gallery-card-info">
                                        <h3 class="gallery-card-title">@artwork.Title</h3>

                                        @if (artwork.Price.HasValue)
                                        {
                                            <p class="gallery-card-price">@artwork.Price.Value.ToString("0.##") €</p>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state">@L["EmptyCategory"]</p>
                }
            }
            else
            {
                @if (string.IsNullOrWhiteSpace(selectedFlow))
                {
                    <div class="public-category-grid">
                        <button type="button"
                                class="public-category-card calligraphy-card"
                                @onclick='() => OpenCategory("Calligraphy")'>
                            <div class="public-category-overlay"></div>
                            <div class="public-category-inner">
                                <h2>Kaligrāfija</h2>
                                <div class="category-line"></div>
                            </div>
                        </button>

                        <button type="button"
                                class="public-category-card xieyi-card"
                                @onclick='() => OpenCategory("Xieyi")'>
                            <div class="public-category-overlay"></div>
                            <div class="public-category-inner">
                                <h2>Sumi-e</h2>
                                <div class="category-line"></div>
                            </div>
                        </button>

                        <button type="button"
                                class="public-category-card chinoiserie-card"
                                @onclick='() => OpenCategory("Chinoiserie")'>
                            <div class="public-category-overlay"></div>
                            <div class="public-category-inner">
                                <h2>Chinoiserie</h2>
                                <div class="category-line"></div>
                            </div>
                        </button>
                    </div>
                }
                else
                {
                    var categoryArtworks = artworks.Where(a => a.Flow == selectedFlow).ToList();
                    var categoryTitle = GetCategoryTitle(selectedFlow);

                    <div class="public-gallery-view">
                        <div class="public-gallery-header">
                            <button type="button" class="back-btn" @onclick="BackToCategories">
                                ← Back
                            </button>

                            <h2 class="gallery-group-title">@categoryTitle</h2>
                        </div>

                        @if (categoryArtworks.Any())
                        {
                            <div class="gallery-grid">
                                @foreach (var artwork in categoryArtworks)
                                {
                                    <div class="gallery-card">
                                        <div class="gallery-card-frame">
                                            <div class="gallery-image-wrap">
                                                <img class="gallery-image" src="@artwork.ImageUrl" alt="@artwork.Title" />

                                                <div class="gallery-hover-info">
                                                    <p><strong>@L["Size"]:</strong> @artwork.Size</p>
                                                    <p><strong>@L["Material"]:</strong> @artwork.Material</p>

                                                    @if (artwork.Year.HasValue)
                                                    {
                                                        <p><strong>@L["Year"]:</strong> @artwork.Year</p>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(artwork.Description))
                                                    {
                                                        <p><strong>@L["Description"]:</strong> @artwork.Description</p>
                                                    }
                                                </div>
                                            </div>

                                            <div class="gallery-card-info">
                                                <h3 class="gallery-card-title">@artwork.Title</h3>

                                                @if (artwork.Price.HasValue)
                                                {
                                                    <p class="gallery-card-price">@artwork.Price.Value.ToString("0.##") €</p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="empty-state">@L["EmptyCategory"]</p>
                        }
                    </div>
                }
            }

        </div>
    </div>
</section>

@code {
    private string? selectedFlow;
    private bool showForm = false;

    private List<ArtworkItem> artworks = new();

    private ArtworkFormModel formModel = new()
    {
        Flow = "Calligraphy"
    };

    private IBrowserFile? uploadedFile;

    private void ToggleForm()
    {
        showForm = !showForm;
    }

    private void OpenCategory(string flow)
    {
        selectedFlow = flow;
    }

    private void BackToCategories()
    {
        selectedFlow = null;
    }

    private string GetCategoryTitle(string flow) => flow switch
    {
        "Calligraphy" => "Kaligrāfija",
        "Xieyi" => "Sumi-e",
        "Chinoiserie" => "Chinoiserie",
        _ => flow
    };

    private void OnUploadedFileChanged(IBrowserFile? file)
    {
        uploadedFile = file;
    }

    private Task AddArtwork()
    {
        var artwork = new ArtworkItem
        {
            Id = Guid.NewGuid(),
            Title = formModel.Title,
            Size = formModel.Size,
            Material = formModel.Material,
            Year = formModel.Year,
            Description = formModel.Description,
            Flow = formModel.Flow,
            Price = formModel.Price,
            ImageUrl = uploadedFile is not null
                ? $"images/{uploadedFile.Name}"
                : "/images/placeholder.jpg"
        };

        artworks.Add(artwork);

        formModel = new ArtworkFormModel
        {
            Flow = "Calligraphy"
        };

        uploadedFile = null;
        showForm = false;

        return Task.CompletedTask; // ✅ THIS FIXES YOUR ERROR
    }

    private void DeleteArtwork(Guid id)
    {
        var item = artworks.FirstOrDefault(x => x.Id == id);
        if (item is not null)
        {
            artworks.Remove(item);
        }
    }
}