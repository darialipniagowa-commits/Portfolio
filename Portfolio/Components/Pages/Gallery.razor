@page "/gallery"
@rendermode InteractiveServer
<Component />@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Gallery> L

<PageTitle>@L["Title"]</PageTitle>

<section class="gallery-section">
    <div class="gallery-container">
        <div class="gallery-content">

            <div class="gallery-heading">
                <h1 class="gallery-title">@L["Title"]</h1>
            </div>

            <div class="mode-switch">
                <button class="filter-btn @(isAdminMode ? "active" : "")"
                        @onclick="() => isAdminMode = true">
                    Admin
                </button>

                <button class="filter-btn @(!isAdminMode ? "active" : "")"
                        @onclick="() => isAdminMode = false">
                    Public
                </button>
            </div>

            @if (isAdminMode)
            {
                <div class="gallery-admin-card">
                    <h2>Add Artwork</h2>

                    <EditForm Model="formModel" OnValidSubmit="AddArtwork" FormName="AddArtworkForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="form-group">
                            <label>Image</label>
                            <InputFile OnChange="HandleImageUpload" />
                        </div>

                        <div class="form-grid">
                            <div class="form-group">
                                <label>Title</label>
                                <InputText @bind-Value="formModel.Title" class="form-input" />
                            </div>

                            <div class="form-group">
                                <label>Size</label>
                                <InputText @bind-Value="formModel.Size" class="form-input" />
                            </div>

                            <div class="form-group">
                                <label>Material</label>
                                <InputText @bind-Value="formModel.Material" class="form-input" />
                            </div>

                            <div class="form-group">
                                <label>Flow</label>
                                <InputSelect @bind-Value="formModel.Flow" class="form-input">
                                    <option value="Calligraphy">Calligraphy</option>
                                    <option value="Xieyi">Xieyi</option>
                                    <option value="Chinoiserie">Chinoiserie</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Price</label>
                            <InputNumber @bind-Value="formModel.Price" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label>Description (optional)</label>
                            <InputTextArea @bind-Value="formModel.Description" class="form-input" />
                        </div>

                        <button type="submit" class="add-btn">Add Artwork</button>
                    </EditForm>
                </div>
            }

            <div class="gallery-groups">
                <section class="gallery-group">
                    <h2 class="gallery-group-title">@L["Calligraphy"]</h2>

                    <div class="gallery-grid">
                        @if (artworks.Any(a => a.Flow == "Calligraphy"))
                        {
                            @foreach (var artwork in artworks.Where(a => a.Flow == "Calligraphy"))
                            {
                                <div class="gallery-card">
                                    <div class="gallery-card-frame">
                                        <div class="gallery-image-wrap">
                                            <img class="gallery-image" src="@artwork.ImageUrl" alt="@artwork.Title" />

                                            <div class="gallery-hover-info">
                                                <p><strong>@L["Size"]:</strong> @artwork.Size</p>
                                                <p><strong>@L["Material"]:</strong> @artwork.Material</p>

                                                @if (artwork.Year.HasValue)
                                                {
                                                    <p><strong>@L["Year"]:</strong> @artwork.Year</p>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(artwork.Description))
                                                {
                                                    <p><strong>@L["Description"]:</strong> @artwork.Description</p>
                                                }
                                            </div>
                                        </div>

                                        <div class="gallery-card-info">
                                            <h3 class="gallery-card-title">@artwork.Title</h3>

                                            @if (artwork.Price.HasValue)
                                            {
                                                <p class="gallery-card-price">@artwork.Price.Value.ToString("0.##") €</p>
                                            }
                                        </div>

                                        @if (isAdminMode)
                                        {
                                            <div class="gallery-card-actions">
                                                <button class="delete-btn" @onclick="() => DeleteArtwork(artwork.Id)">
                                                    Delete
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="empty-state">@L["EmptyCategory"]</p>
                        }
                    </div>
                </section>

                <section class="gallery-group">
                    <h2 class="gallery-group-title">@L["Xieyi"]</h2>

                    <div class="gallery-grid">
                        @if (artworks.Any(a => a.Flow == "Xieyi"))
                        {
                            @foreach (var artwork in artworks.Where(a => a.Flow == "Xieyi"))
                            {
                                <div class="gallery-card">
                                    <div class="gallery-card-frame">
                                        <div class="gallery-image-wrap">
                                            <img class="gallery-image" src="@artwork.ImageUrl" alt="@artwork.Title" />

                                            <div class="gallery-hover-info">
                                                <p><strong>@L["Size"]:</strong> @artwork.Size</p>
                                                <p><strong>@L["Material"]:</strong> @artwork.Material</p>

                                                @if (artwork.Year.HasValue)
                                                {
                                                    <p><strong>@L["Year"]:</strong> @artwork.Year</p>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(artwork.Description))
                                                {
                                                    <p><strong>@L["Description"]:</strong> @artwork.Description</p>
                                                }
                                            </div>
                                        </div>

                                        <div class="gallery-card-info">
                                            <h3 class="gallery-card-title">@artwork.Title</h3>

                                            @if (artwork.Price.HasValue)
                                            {
                                                <p class="gallery-card-price">@artwork.Price.Value.ToString("0.##") €</p>
                                            }
                                        </div>

                                        @if (isAdminMode)
                                        {
                                            <div class="gallery-card-actions">
                                                <button class="delete-btn" @onclick="() => DeleteArtwork(artwork.Id)">
                                                    Delete
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="empty-state">@L["EmptyCategory"]</p>
                        }
                    </div>
                </section>

                <section class="gallery-group">
                    <h2 class="gallery-group-title">@L["Chinoiserie"]</h2>

                    <div class="gallery-grid">
                        @if (artworks.Any(a => a.Flow == "Chinoiserie"))
                        {
                            @foreach (var artwork in artworks.Where(a => a.Flow == "Chinoiserie"))
                            {
                                <div class="gallery-card">
                                    <div class="gallery-card-frame">
                                        <div class="gallery-image-wrap">
                                            <img class="gallery-image" src="@artwork.ImageUrl" alt="@artwork.Title" />

                                            <div class="gallery-hover-info">
                                                <p><strong>@L["Size"]:</strong> @artwork.Size</p>
                                                <p><strong>@L["Material"]:</strong> @artwork.Material</p>

                                                @if (artwork.Year.HasValue)
                                                {
                                                    <p><strong>@L["Year"]:</strong> @artwork.Year</p>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(artwork.Description))
                                                {
                                                    <p><strong>@L["Description"]:</strong> @artwork.Description</p>
                                                }
                                            </div>
                                        </div>

                                        <div class="gallery-card-info">
                                            <h3 class="gallery-card-title">@artwork.Title</h3>

                                            @if (artwork.Price.HasValue)
                                            {
                                                <p class="gallery-card-price">@artwork.Price.Value.ToString("0.##") €</p>
                                            }
                                        </div>

                                        @if (isAdminMode)
                                        {
                                            <div class="gallery-card-actions">
                                                <button class="delete-btn" @onclick="() => DeleteArtwork(artwork.Id)">
                                                    Delete
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="empty-state">@L["EmptyCategory"]</p>
                        }
                    </div>
                </section>
            </div>
        </div>
    </div>
</section>

@code {
    private bool isAdminMode = true;

    private List<ArtworkItem> artworks = new();

    private ArtworkFormModel formModel = new()
    {
        Flow = "Calligraphy"
    };

    private IBrowserFile? uploadedFile;

    private void HandleImageUpload(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
    }

    private Task AddArtwork()
    {
        var artwork = new ArtworkItem
        {
            Id = Guid.NewGuid(),
            Title = formModel.Title,
            Size = formModel.Size,
            Material = formModel.Material,
            Year = formModel.Year,
            Description = formModel.Description,
            Flow = formModel.Flow,
            Price = formModel.Price,
            ImageUrl = uploadedFile is not null
                ? $"images/{uploadedFile.Name}"
                : "/images/placeholder.jpg"
        };

        artworks.Add(artwork);

        formModel = new ArtworkFormModel
        {
            Flow = "Calligraphy"
        };

        uploadedFile = null;

        return Task.CompletedTask;
    }

    private void DeleteArtwork(Guid id)
    {
        var item = artworks.FirstOrDefault(x => x.Id == id);
        if (item is not null)
        {
            artworks.Remove(item);
        }
    }
}