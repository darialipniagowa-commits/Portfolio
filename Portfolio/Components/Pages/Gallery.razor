@page "/gallery"
@rendermode InteractiveServer

@using Portfolio.Models
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components.Forms
@inject IStringLocalizer<Gallery> L
@inject Portfolio.Services.AdminState AdminState
@inject Portfolio.Services.ArtworkService ArtworkService

<PageTitle>@L["Title"]</PageTitle>

<section class="gallery-section">
    <div class="gallery-container">
        <div class="gallery-content">

            <div class="gallery-heading">
                <img class="gallery-header-image"
                     src="@HeaderImage"
                     alt="@L["Title"]" />
            </div>

            @if (AdminState.IsAdmin)
            {
                <div class="gallery-admin-actions">
                    <button class="add-btn" type="button" @onclick="ToggleForm">
                        @(showForm ? "Close" : "+ Add Artwork")
                    </button>
                </div>
            }

            @if (AdminState.IsAdmin && showForm)
            {
                <AdminArtworks FormModel="formModel"
                               UploadedFileChanged="OnUploadedFileChanged"
                               OnSubmit="AddArtwork" />
            }

            @if (AdminState.IsAdmin)
            {
                @if (artworks.Any())
                {
                    <div class="gallery-grid">
                        @foreach (var artwork in artworks)
                        {
                            <GalleryCard Artwork="artwork"
                                         IsAdmin="true"
                                         OnDelete="DeleteArtwork" />
                        }
                    </div>
                }
                else
                {
                    <p class="empty-state">@L["EmptyCategory"]</p>
                }
            }
            else
            {
                @if (string.IsNullOrWhiteSpace(selectedFlow))
                {
                    <div class="public-category-grid">
                        <button type="button" class="public-category-card" @onclick='() => OpenCategory("Calligraphy")'>
                            <img class="category-switch-image" src="@CalligraphyCategoryImage" alt="@L["Calligraphy"]" />
                        </button>

                        <button type="button" class="public-category-card" @onclick='() => OpenCategory("Xieyi")'>
                            <img class="category-switch-image" src="@XieyiCategoryImage" alt="@L["Xieyi"]" />
                        </button>

                        <button type="button" class="public-category-card" @onclick='() => OpenCategory("Chinoiserie")'>
                            <img class="category-switch-image" src="@ChinoiserieCategoryImage" alt="@L["Chinoiserie"]" />
                        </button>
                    </div>
                }
                else
                {
                    var categoryArtworks = artworks
                        .Where(a => a.Flow == selectedFlow)
                        .ToList();

                    <div class="public-gallery-view">
                        <div class="public-gallery-header">
                            <button type="button" class="back-btn" @onclick="BackToCategories">
                                ← Back
                            </button>

                            <h2 class="gallery-group-title">@GetCategoryTitle(selectedFlow)</h2>
                        </div>

                        @if (categoryArtworks.Any())
                        {
                            <div class="gallery-grid">
                                @foreach (var artwork in categoryArtworks)
                                {
                                    <GalleryCard Artwork="artwork"
                                                 IsAdmin="false"
                                                 OnDelete="DeleteArtwork" />
                                }
                            </div>
                        }
                        else
                        {
                            <p class="empty-state">@L["EmptyCategory"]</p>
                        }
                    </div>
                }
            }

        </div>
    </div>
</section>

@code {
    private string? selectedFlow;
    private bool showForm;
    private IBrowserFile? uploadedFile;

    private List<ArtworkItem> artworks = new();

    private ArtworkFormModel formModel = new()
    {
        Flow = "Calligraphy"
    };

    private bool IsLv =>
        System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "lv";

    private string HeaderImage =>
        IsLv ? "/gallery/name2.png" : "/gallery/finseng.png";

    private string CalligraphyCategoryImage =>
        IsLv ? "/gallery/lv1.png" : "/gallery/eng1.png";

    private string XieyiCategoryImage =>
        IsLv ? "/gallery/lv2.png" : "/gallery/eng2.png";

    private string ChinoiserieCategoryImage =>
        IsLv ? "/gallery/lv3.png" : "/gallery/eng3.png";
        protected override async Task OnInitializedAsync()
{
    artworks = await ArtworkService.GetArtworksAsync();
}
    private void ToggleForm()
    {
        showForm = !showForm;
    }

    private void OpenCategory(string flow)
    {
        selectedFlow = flow;
    }

    private void BackToCategories()
    {
        selectedFlow = null;
    }

    private string GetCategoryTitle(string flow) => flow switch
    {
        "Calligraphy" => L["Calligraphy"],
        "Xieyi" => L["Xieyi"],
        "Chinoiserie" => L["Chinoiserie"],
        _ => flow
    };

    private void OnUploadedFileChanged(IBrowserFile? file)
    {
        uploadedFile = file;
    }

   private async Task AddArtwork()
{
    var imageUrl = "/images/placeholder.jpg";

    if (uploadedFile is not null)
    {
        imageUrl = await ArtworkService.SaveImageAsync(uploadedFile);
    }

    var artwork = new ArtworkItem
    {
        Id = Guid.NewGuid(),
        Title = formModel.Title,
        Size = formModel.Size,
        Material = formModel.Material,
        Year = formModel.Year,
        Description = formModel.Description,
        Flow = formModel.Flow,
        Price = formModel.Price,
        ImageUrl = imageUrl
    };

    await ArtworkService.AddArtworkAsync(artwork);

    artworks = await ArtworkService.GetArtworksAsync();

    formModel = new ArtworkFormModel
    {
        Flow = "Calligraphy"
    };

    uploadedFile = null;
    showForm = false;
}

   private async Task DeleteArtwork(Guid id)
{
    await ArtworkService.DeleteArtworkAsync(id);

    artworks = await ArtworkService.GetArtworksAsync();
}
}