@using Portfolio.Models

<div class="artwork-card">
    <div class="artwork-image-wrap">
        <img class="artwork-image"
             src="@Artwork.ImageUrl"
             alt="@Artwork.Title" />

        <div class="artwork-hover">
            <p>@Artwork.Size</p>
            <p>@Artwork.Year</p>
            <p>@Artwork.Material</p>

            @if (!string.IsNullOrWhiteSpace(Artwork.Description))
            {
                <p>@Artwork.Description</p>
            }
        </div>
    </div>
    </div>

    <div class="artwork-bottom">
        <span class="artwork-title">@Artwork.Title</span>

        @if (Artwork.Price > 0)
        {
            <span class="artwork-price">@Artwork.Price €</span>
        }
    </div>
    <div class="artwork-image-wrap">
        <img class="artwork-image"
             src="@Artwork.ImageUrl"
             alt="@Artwork.Title" />

        @if (IsAdmin)
        {
            <button type="button"
                    class="delete-x"
                    @onclick="Delete">
                ×
            </button>
        }
        @if (IsAdmin)
        {
            <button type="button"
                    class="delete-btn"
                    @onclick="Delete">
                Delete
            </button>
        }
    </div>

@code {
    [Parameter] public ArtworkItem Artwork { get; set; } = new();
    [Parameter] public bool IsAdmin { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    private async Task Delete()
    {
        await OnDelete.InvokeAsync(Artwork.Id);
    }
}