@page "/projects"
@rendermode InteractiveServer

@using Portfolio.Models
@using Microsoft.AspNetCore.Components.Forms
@inject Portfolio.Services.AdminState AdminState

<PageTitle>Digital Portfolio</PageTitle>

<section class="portfolio-page">
    <div class="portfolio-container">
        <header class="portfolio-header">
            <h1 class="portfolio-title">@PortfolioTitle</h1>

            <div class="portfolio-divider-row">
                <div class="line"></div>
                <div class="circle"></div>
                <div class="line"></div>

                <div class="seal">印</div>
            </div>
        </header>
        @if (AdminState.IsAdmin)
        {
            <div class="portfolio-admin-actions">
                <button class="add-btn" type="button" @onclick="ToggleForm">
                    @(showForm ? "Close" : "+ Add Project")
                </button>
            </div>
        }

        @if (AdminState.IsAdmin && showForm)
        {
            <div class="admin-panel">
                <EditForm Model="@formModel" OnValidSubmit="AddProject">
                    <div class="form-grid">

                        <div class="form-field">
                            <label>Name</label>
                            <InputText @bind-Value="formModel.Name" class="form-input" />
                        </div>

                        <div class="form-field">
                            <label>Year</label>
                            <InputText @bind-Value="formModel.Year" class="form-input" />
                        </div>

                        <div class="form-field full-width">
                            <label>Demo Image URL</label>
                            <InputText @bind-Value="formModel.DemoUrl" class="form-input" />
                        </div>

                        <div class="form-field full-width">
                            <label>GitHub URL</label>
                            <InputText @bind-Value="formModel.GitHubUrl" class="form-input" />
                        </div>

                        <div class="form-field full-width">
                            <label>Idea</label>
                            <InputTextArea @bind-Value="formModel.Idea" class="form-input textarea" />
                        </div>

                        <div class="form-field full-width">
                            <label>Structure</label>
                            <InputTextArea @bind-Value="formModel.Structure" class="form-input textarea" />
                        </div>

                    </div>

                    <button class="save-btn" type="submit">Save Project</button>
                </EditForm>
            </div>
        }

        @if (projects.Any())
        {
            <div class="projects-grid">
                @foreach (var project in projects)
                {
                    <div class="project-card">
                        @if (AdminState.IsAdmin)
                        {
                            <button class="delete-btn" @onclick="() => DeleteProject(project.Id)">×</button>
                        }

                        <div class="project-head">
                            <p class="project-year">@project.Year</p>
                            <h2 class="project-name">@project.Name</h2>
                        </div>

                        <div class="project-main">
                            <div class="project-demo-side">
                                <div class="demo-box">
                                    @if (openedDemoId == project.Id && !string.IsNullOrWhiteSpace(project.DemoUrl))
                                    {
                                        <img src="@project.DemoUrl" alt="@($"{project.Name} demo")" />
                                    }
                                    else
                                    {
                                        <div class="demo-placeholder">Demo preview</div>
                                    }
                                </div>
                            </div>

                            <div class="project-text-side">
                                <div class="text-block">
                                    <h4>Idea</h4>
                                    <p>@project.Idea</p>
                                </div>

                                <div class="text-divider"></div>

                                <div class="text-block">
                                    <h4>Structure</h4>
                                    <p>@project.Structure</p>
                                </div>
                            </div>
                        </div>

                        <div class="project-footer">
                            <button class="demo-btn" @onclick="() => ToggleDemo(project.Id)">
                                Demo
                            </button>

                            @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                            {
                                <a class="github-link" href="@project.GitHubUrl" target="_blank" rel="noopener noreferrer">
                                    GitHub
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">No portfolio projects added yet.</p>
        }

    </div>
</section>

@code {
    private Guid? openedDemoId;
    private bool showForm;

    private List<PortfolioItem> projects = new();

    private PortfolioItem formModel = new()
    {
        Id = Guid.NewGuid()
    };

    private void ToggleForm()
    {
        showForm = !showForm;
    }

    private void AddProject()
    {
        formModel.Id = Guid.NewGuid();
        projects.Add(formModel);

        formModel = new PortfolioItem
        {
            Id = Guid.NewGuid()
        };

        showForm = false;
    }

    private void ToggleDemo(Guid id)
    {
        openedDemoId = openedDemoId == id ? null : id;
    }

    private void DeleteProject(Guid id)
    {
        var item = projects.FirstOrDefault(x => x.Id == id);

        if (item is not null)
        {
            projects.Remove(item);

            if (openedDemoId == id)
                openedDemoId = null;
        }
    }
    private string PortfolioTitle =>
    System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "lv"
        ? "Digitālais Portfolio"
        : "Digital Portfolio";
    private string HeaderImage =>
        System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "lv"
            ? "/dproject/dphlv.png"
            : "/dproject/dphen.png";
}