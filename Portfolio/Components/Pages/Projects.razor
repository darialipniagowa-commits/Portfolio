@page "/projects"
@rendermode InteractiveServer

@using Portfolio.Models
@using Microsoft.AspNetCore.Components.Forms
@inject Portfolio.Services.AdminState AdminState
@inject Portfolio.Services.PortfolioProjectService ProjectService

<PageTitle>@PortfolioTitle</PageTitle>

<section class="portfolio-page">
    <div class="portfolio-container">

        <!-- HEADER -->
        <div class="portfolio-header">
            <img class="portfolio-header-img"
                 src="@HeaderImage"
                 alt="@PortfolioTitle" />
        </div>

        <!-- ADMIN BUTTON -->
        @if (AdminState.IsAdmin)
        {
            <div class="portfolio-admin-actions">
                <button class="add-btn" type="button" @onclick="ToggleForm">
                    @(showForm ? "Close" : "+ Add Project")
                </button>
            </div>
        }

        <!-- ADMIN FORM -->
        @if (AdminState.IsAdmin && showForm)
        {
            <div class="project-admin-panel">
                <h2>Add Project</h2>

                <EditForm Model="@formModel" OnValidSubmit="AddProject">
                    <div class="project-form-grid">

                        <div class="project-form-field">
                            <label>Name</label>
                            <InputText @bind-Value="formModel.Name" />
                        </div>

                        <div class="project-form-field">
                            <label>Year</label>
                            <InputText @bind-Value="formModel.Year" />
                        </div>

                        <div class="project-form-field full">
                            <label>Preview Image URL</label>
                            <InputText @bind-Value="formModel.ImageUrl" />
                        </div>

                        <div class="project-form-field full">
                            <label>Demo GIF URL</label>
                            <InputText @bind-Value="formModel.DemoUrl" />
                        </div>

                        <div class="project-form-field full">
                            <label>GitHub URL</label>
                            <InputText @bind-Value="formModel.GitHubUrl" />
                        </div>

                        <div class="project-form-field full">
                            <label>Idea</label>
                            <InputTextArea @bind-Value="formModel.Idea" />
                        </div>

                        <div class="project-form-field full">
                            <label>Structure</label>
                            <InputTextArea @bind-Value="formModel.Structure" />
                        </div>

                    </div>

                    <div class="project-admin-buttons">
                        <button class="save-project-btn" type="submit">Save Project</button>
                        <button class="cancel-project-btn" type="button" @onclick="ToggleForm">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        <!-- PROJECT LIST (VISIBLE TO PUBLIC) -->
        @if (projects.Any())
        {
            <div class="projects-list">
                @foreach (var project in projects)
                {
                    <article class="project-card">

                        @if (AdminState.IsAdmin)
                        {
                            <button class="delete-btn"
                                    type="button"
                                    @onclick="() => DeleteProject(project.Id)">
                                ×
                            </button>
                        }

                        <header class="project-head">
                            @if (!string.IsNullOrWhiteSpace(project.Year))
                            {
                                <p class="project-year">@project.Year</p>
                            }

                            <h2 class="project-name">@project.Name</h2>
                        </header>

                        <div class="project-line"></div>

                        <div class="project-main">

                            <!-- IMAGE / GIF -->
                            <div class="project-image-box">
                                @if (openedDemoId == project.Id && !string.IsNullOrWhiteSpace(project.DemoUrl))
                                {
                                    <img src="@project.DemoUrl" alt="@($"{project.Name} demo")" />
                                }
                                else if (!string.IsNullOrWhiteSpace(project.ImageUrl))
                                {
                                    <img src="@project.ImageUrl" alt="@project.Name" />
                                }
                                else
                                {
                                    <div class="demo-placeholder">Demo preview</div>
                                }
                            </div>

                            <!-- TEXT -->
                            <div class="project-text-side">
                                <div class="text-block">
                                    <h4>Idea</h4>
                                    <p>@project.Idea</p>
                                </div>

                                <div class="text-block">
                                    <h4>Structure</h4>
                                    <p>@project.Structure</p>
                                </div>
                            </div>

                        </div>

                        <!-- FOOTER -->
                        <footer class="project-footer">
                            <button class="demo-btn"
                                    type="button"
                                    @onclick="() => ToggleDemo(project.Id)">
                                @(openedDemoId == project.Id ? "Back" : "Demo")
                            </button>

                            @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                            {
                                <a class="github-link"
                                       href="@project.GitHubUrl"
                                       target="_blank"
                                       rel="noopener noreferrer">
                                    GitHub
                                </a>
                            }
                        </footer>

                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">No portfolio projects added yet.</p>
        }

    </div>
</section>

@code {
    private Guid? openedDemoId;
    private bool showForm;

    // 🔥 IMPORTANT: shared data
    private List<PortfolioItem> projects => ProjectService.Projects;

    private PortfolioItem formModel = new()
    {
        Id = Guid.NewGuid()
    };

    private void ToggleForm()
    {
        showForm = !showForm;
    }

    private void AddProject()
    {
        formModel.Id = Guid.NewGuid();

        ProjectService.Add(formModel);

        formModel = new PortfolioItem
        {
            Id = Guid.NewGuid()
        };

        showForm = false;
    }

    private void ToggleDemo(Guid id)
    {
        openedDemoId = openedDemoId == id ? null : id;
    }

    private void DeleteProject(Guid id)
    {
        ProjectService.Delete(id);

        if (openedDemoId == id)
            openedDemoId = null;
    }

    private string PortfolioTitle =>
        System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "lv"
            ? "Digitālais Portfolio"
            : "Digital Portfolio";

    private string HeaderImage =>
        System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "lv"
            ? "/dproject/dplv.png"
            : "/dproject/dpeng.png";
}