@page "/projects"
@rendermode InteractiveServer

@using Portfolio.Models
@inject Portfolio.Services.AdminState AdminState

<PageTitle>Digital Portfolio</PageTitle>

<section class="portfolio-page">
    <div class="portfolio-container">

        <header class="portfolio-header">
            <h1 class="portfolio-title">Digital Portfolio</h1>
        </header>

        @if (projects.Any())
        {
            <div class="projects-grid">
                @foreach (var project in projects)
                {
                    <div class="project-card">
                        @if (AdminState.IsAdmin)
                        {
                            <button class="delete-btn" @onclick="() => DeleteProject(project.Id)">×</button>
                        }

                        <div class="project-head">
                            <p class="project-year">@project.Year</p>
                            <h2 class="project-name">@project.Name</h2>
                        </div>

                        <div class="project-main">
                            <div class="project-demo-side">
                                <div class="demo-box">
                                    @if (openedDemoId == project.Id && !string.IsNullOrWhiteSpace(project.DemoUrl))
                                    {
                                        <img src="@project.DemoUrl" alt="@($"{project.Name} demo")" />
                                    }
                                    else
                                    {
                                        <div class="demo-placeholder">Demo preview</div>
                                    }
                                </div>
                            </div>

                            <div class="project-text-side">
                                <div class="text-block">
                                    <h4>Idea</h4>
                                    <p>@project.Idea</p>
                                </div>

                                <div class="text-divider"></div>

                                <div class="text-block">
                                    <h4>Structure</h4>
                                    <p>@project.Structure</p>
                                </div>
                            </div>
                        </div>

                        <div class="project-footer">
                            <button class="demo-btn" @onclick="() => ToggleDemo(project.Id)">
                                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M8 5v14l11-7z"></path>
                                </svg>
                                Demo
                            </button>

                            @if (!string.IsNullOrWhiteSpace(project.GitHubUrl))
                            {
                                <a class="github-link" href="@project.GitHubUrl" target="_blank" rel="noopener noreferrer">
                                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                        <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.42-4.04-1.42a3.18 3.18 0 0 0-1.34-1.76c-1.1-.76.08-.75.08-.75a2.5 2.5 0 0 1 1.82 1.22 2.54 2.54 0 0 0 3.47 1 2.54 2.54 0 0 1 .76-1.59c-2.67-.31-5.47-1.34-5.47-5.95a4.66 4.66 0 0 1 1.24-3.24 4.32 4.32 0 0 1 .12-3.2s1-.32 3.3 1.24a11.35 11.35 0 0 1 6 0c2.28-1.56 3.29-1.24 3.29-1.24a4.32 4.32 0 0 1 .12 3.2 4.66 4.66 0 0 1 1.24 3.24c0 4.62-2.8 5.64-5.48 5.95a2.84 2.84 0 0 1 .81 2.2v3.26c0 .32.21.7.83.58A12 12 0 0 0 12 .5z"></path>
                                    </svg>
                                    GitHub
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">No portfolio projects added yet.</p>
        }

    </div>
</section>

@code {
    private Guid? openedDemoId;

    private List<PortfolioItem> projects = new();

    private void ToggleDemo(Guid id)
    {
        if (openedDemoId == id)
            openedDemoId = null;
        else
            openedDemoId = id;
    }

    private void DeleteProject(Guid id)
    {
        var item = projects.FirstOrDefault(x => x.Id == id);
        if (item is not null)
        {
            projects.Remove(item);

            if (openedDemoId == id)
                openedDemoId = null;
        }
    }
}